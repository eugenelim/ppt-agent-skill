    {
      "names": [
        "clone"
      ],
      "action": "SCMP_ACT_ALLOW",
      "comment": "Allow clone for Chromium process model. Containment against namespace-based escape relies on blocking mount and pivot_root (not on blocking CLONE_NEWUSER, which requires no capability). SYS_ADMIN is granted for Chromium sandboxed renderer startup."
    },
    {
      "names": [
        "clone3"
      ],
      "action": "SCMP_ACT_ERRNO",
      "comment": "Block clone3 with ENOSYS (not EPERM) so glibc >=2.34 falls back to clone() rather than failing process/thread creation. Chromium uses clone(); clone3 is not needed.",
      "errnoRet": 38
    },
    {
      "names": [
        "mount"
      ],
      "action": "SCMP_ACT_ERRNO",
      "comment": "Block filesystem mount \u2014 hard container-isolation boundary."
    },
    {
      "names": [
        "pivot_root"
      ],
      "action": "SCMP_ACT_ERRNO",
      "comment": "Block pivot_root \u2014 prevents container root filesystem re-anchoring."
    },
    {
      "names": [
        "unshare"
      ],
      "action": "SCMP_ACT_ERRNO",
      "comment": "Block unshare \u2014 prevents ad-hoc namespace creation outside the controlled Chromium sandbox path."
    },
    {
      "names": [
        "setns"
      ],
      "action": "SCMP_ACT_ERRNO",
      "comment": "Block setns \u2014 prevents a compromised process from joining host or sibling container namespaces."
    }
  ],
  "defaultErrnoRet": 38
