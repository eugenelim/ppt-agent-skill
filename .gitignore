node_modules/
.vscode/
.superpowers/
.DS_Store

# 运行时产物（style-gallery/ 保留 26 风格预览用于 README 效果展示）
ppt-output/*
!ppt-output/style-gallery/

# 测试结果：新运行目录为临时产物，不入库（已提交的历史里程碑报告仍保留 —
# .gitignore 只影响未跟踪文件）。运行时图片同样不入库。
tests/smoke-results/
tests/smoke-results/*/screenshots/

# Puppeteer 运行时产物
*.bundle.js

# html2svg 每次转换的唯一临时目录（正常运行会自清理，此处兜底残留）
.h2svg-*/

# ── agent-ready-repo (core pack) ──────────────────────────────
# Local install-time scratch — written by `agentbundle install`.
.adapt-install-marker.toml

# Work-loop session state — per-spec scratch, never committed.
docs/specs/**/state.json

# Supervisor-mode worktrees.
.worktrees/

# Implementer reports — session-scratch.
docs/specs/**/notes/implementer-*.md

# Personal Claude Code overrides.
CLAUDE.local.md
.claude/settings.local.json
AGENTS.local.md

# OS / editor noise.
*.swp
.idea/

# Python build artefacts.
__pycache__/
*.egg-info/
*.pyc
build/

# Build pipeline output.
dist/

# Conductor scratch + per-workspace probe scaffolding.
.context/
